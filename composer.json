{
    "name": "wpgov/wp-governance",
    "description": "File-based WordPress governance mu-plugin — restrict features, capabilities, and admin UI via config.",
    "type": "wordpress-muplugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "wp-phpunit/wp-phpunit": "^6.4",
        "yoast/phpunit-polyfills": "^2.0",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcsstandards/phpcsutils": "^1.0",
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/wp-cli-stubs": "^2.0"
    },
    "autoload": {
        "classmap": [
            "wp-governance/"
        ]
    },
    "scripts": {
        "analyze": "phpstan analyse --no-progress --memory-limit=1G",
        "lint": "phpcs --standard=phpcs.xml.dist",
        "lint:syntax": "@php bin/lint.php",
        "test": "phpunit",
        "test:all": "@lint:syntax && @lint && @analyze && @test",
        "test:coverage": "phpunit --coverage-html=coverage"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
