<?xml version="1.0"?>
<ruleset name="WP Governance Focused Checks">
	<description>Focused WPCS rules for production-risk checks in WP Governance runtime code.</description>

	<file>wp-governance.php</file>
	<file>wp-governance</file>

	<exclude-pattern>*/wp-governance/wp-governance-config.php</exclude-pattern>
	<exclude-pattern>*/wp-governance/class-cli.php</exclude-pattern>

	<arg name="extensions" value="php" />
	<arg value="sp" />

	<rule ref="WordPress.Security.EscapeOutput" />
	<rule ref="WordPress.Security.ValidatedSanitizedInput" />
	<rule ref="WordPress.DB.DirectDatabaseQuery" />
	<rule ref="WordPress.DB.PreparedSQL" />
</ruleset>
