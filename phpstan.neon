includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 5
    paths:
        - wp-governance.php
        - wp-governance/
    excludePaths:
        - wp-governance/wp-governance-config.php
    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
        - vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php
    ignoreErrors:
        - '#Constructor of class WP_Governance\\Modules\\[A-Za-z_]+ has an unused parameter \$config#'
